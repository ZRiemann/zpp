    "nng_net":{
        "pub_sub":{
            "ingress_endpoint": "ipc:///tmp/test_nng_pub_sub.sock",
            "egress_endpoints": [
                "tcp://127.0.0.1:5555"
            ],
            "topics": [""],
            "socket_options": {
                "recv_queue_depth": 1024,
                "send_queue_depth": 1024,
                "recv_timeout_ms": 1000,
                "send_timeout_ms": 1000
            },

            "listener_options": {
                "max_recv_size_bytes": 1048576
            },

            "dialer_options": {
                "reconnect_min_ms": 3000,
                "reconnect_max_ms": 10000,
                "max_recv_size_bytes": 1048576
            },

            "transport_options": {
                "tcp": {
                    "nodelay": true,
                    "keepalive": true
                },
                "ipc": {
                    "permissions": "0600"
                },
                "tls": {
                    "profile": "internal-mtls"
                }
            }
        },
        "pipeline": {
            "endpoints": [
                "ipc:///tmp/zpp_nng_pipeline.sock"
            ],
            "socket_options": {
                "recv_queue_depth": 128,
                "send_queue_depth": 128,
                "recv_timeout_ms": 1000,
                "send_timeout_ms": 1000
            }
        },
        "request_reply": {
            "endpoints": [
                "ipc:///tmp/zpp_nng_request_reply.sock"
            ],
            "socket_options": {
                "recv_queue_depth": 128,
                "send_queue_depth": 128,
                "recv_timeout_ms": 5000,
                "send_timeout_ms": 1000
            }
        },
        "pair1": {
            "endpoints": [
                "ipc:///tmp/zpp_nng_pair1.sock"
            ],
            "socket_options": {
                "recv_queue_depth": 128,
                "send_queue_depth": 128,
                "recv_timeout_ms": 1000,
                "send_timeout_ms": 1000
            }
        }
    },
